rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Elderly profiles — no Firebase Auth for elderly users (IC-based login only)
    match /elderly/{elderlyId} {
      allow read, write: if true;

      match /daily_checkins/{checkinId} {
        allow read, write: if true;
      }

      match /sos_alerts/{alertId} {
        allow read, write: if true;
      }

      match /medications/{medId} {
        allow read, write: if true;

        match /logs/{logId} {
          allow read, write: if true;
        }
      }
    }

    // Written by elderly (no auth) when SOS fires; read by caregivers (auth)
    match /caregiver_alerts/{caregiverId} {
      allow read, write: if true;

      match /alerts/{alertId} {
        allow read, write: if true;
      }
    }

    // Caregiver profiles — caregivers use Firebase Auth
    match /caregivers/{caregiverId} {
      allow read, write: if request.auth != null;

      match /patients/{patientId} {
        allow read, write: if request.auth != null;

        match /settings/{settingId} {
          allow read, write: if request.auth != null;
        }
      }
    }
  }
}
